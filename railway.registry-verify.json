{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "services/registry-verify/Dockerfile",
    "watchPatterns": [
      "registry/**",
      "scripts/verify-registry.mjs",
      "services/registry-verify/**",
      "railway.registry-verify.json"
    ]
  },
  "deploy": {
    "startCommand": "node scripts/verify-registry.mjs",
    "restartPolicyType": "NEVER",
    "cronSchedule": "23 6 * * 1"
  }
}
